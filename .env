DATABASE_URL=postgresql+asyncpg://llm_user:llm_password@localhost:5432/llm_service
REDIS_URL=redis://localhost:6379/0

# LLM providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# RAG (Pinecone)
PINECONE_API_KEY=
