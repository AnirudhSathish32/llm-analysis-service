DATABASE_URL=postgresql+asyncpg://dev_user:dev_password@localhost:5432/llm_service
REDIS_URL=redis://localhost:6379/0

# LLM providers
ANTHROPIC_API_KEY=dummy-key-for-local-dev
GEMINI_API_KEY=dummy-key-for-local-dev
PINECONE_API_KEY=dummy-key-for-local-dev
