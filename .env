DATABASE_URL=postgresql+asyncpg://llm_user:llm_password@localhost:5432/llm_service
REDIS_URL=redis://localhost:6379/0

# LLM providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Optional tuning (these have defaults in rag_pipeline.py so not strictly required)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=4
CACHE_TTL_SECONDS=3600