# Database - REQUIRED: Set your real DATABASE_URL
DATABASE_URL=postgresql+asyncpg://your_user:your_password@db:5432/llm_service

# Redis
REDIS_URL=redis://redis:6379/0

# LLM providers - REQUIRED for analysis to work
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=AIza-your-key-here

# RAG (Pinecone) - REQUIRED if using document analysis
PINECONE_API_KEY=pcsk-your-key-here
PINECONE_INDEX=llm-analysis-service

# Optional tuning (defaults shown)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=4
CACHE_TTL_SECONDS=3600
