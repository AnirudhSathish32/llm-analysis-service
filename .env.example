# Database
DATABASE_URL=postgresql+asyncpg://llm_user:llm_password@db:5432/llm_service

# Redis
REDIS_URL=redis://redis:6379/0

# LLM Providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# RAG (Pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=llm-analysis-service

# Optional tuning
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=4
CACHE_TTL_SECONDS=3600
